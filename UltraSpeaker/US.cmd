@echo off
setlocal
set "TMPPS=%TEMP%\UltraSpeakerInstaller_%RANDOM%%RANDOM%.ps1"
set "SOURCEDIR=%~dp0"
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$cmd='%~f0'; $tmp=$env:TMPPS; $src=$env:SOURCEDIR.TrimEnd('\'); $lines=Get-Content -LiteralPath $cmd; $idx=[Array]::IndexOf($lines,'__POWERSHELL_PAYLOAD__'); if ($idx -lt 0) { throw 'Payload no encontrado.' }; $payload=$lines[($idx+1)..($lines.Length-1)]; Set-Content -LiteralPath $tmp -Value $payload -Encoding UTF8; $argList=@('-NoProfile','-ExecutionPolicy','Bypass','-File', $tmp, '-SourceDir', $src); Start-Process powershell.exe -WindowStyle Hidden -Verb RunAs -ArgumentList $argList"
if errorlevel 1 pause
exit /b
__POWERSHELL_PAYLOAD__
param(
    [string]$SourceDir = ""
)

$ErrorActionPreference = "Stop"

function Test-IsAdministrator {
    $identity = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = [Security.Principal.WindowsPrincipal]::new($identity)
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

if (-not (Test-IsAdministrator)) {
    $psi = [System.Diagnostics.ProcessStartInfo]::new()
    $psi.FileName = "powershell.exe"
    $psi.Arguments = "-ExecutionPolicy Bypass -File `"$PSCommandPath`" -SourceDir `"$SourceDir`""
    $psi.Verb = "runas"
    try { [System.Diagnostics.Process]::Start($psi) | Out-Null } catch { throw "Instalacion cancelada: se requieren permisos de administrador." }
    exit
}

$scriptDir = if ($SourceDir) {
    $SourceDir
} elseif ($env:ORIGINALDIR) {
    $env:ORIGINALDIR.TrimEnd('\')
} elseif ($env:ULTRASPEAKER_INSTALLER_DIR) {
    $env:ULTRASPEAKER_INSTALLER_DIR
} elseif ($PSScriptRoot -and -not $PSScriptRoot.StartsWith([IO.Path]::GetTempPath(), [StringComparison]::OrdinalIgnoreCase)) {
    $PSScriptRoot
} elseif ((Get-Location).Path) {
    (Get-Location).Path
} else {
    Split-Path -Parent $PSCommandPath
}
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$downloads = Join-Path $env:USERPROFILE "Downloads"
$locationName = Split-Path -Leaf $scriptDir

if (($scriptDir -ieq $desktop) -or ($scriptDir -ieq $downloads) -or ($locationName -ieq "Desktop") -or ($locationName -ieq "Downloads") -or ($locationName -ieq "Descargas") -or ($locationName -ieq "Escritorio")) {
    $installDir = Join-Path $documents "UltraSpeaker"
} else {
    $installDir = $scriptDir
}

New-Item -ItemType Directory -Force -Path $installDir | Out-Null
$tempRoot = Join-Path ([IO.Path]::GetTempPath()) ("UltraSpeakerInstall_" + [Guid]::NewGuid().ToString("N"))
New-Item -ItemType Directory -Force -Path $tempRoot | Out-Null
$zipPath = Join-Path $tempRoot "payload.zip"
$payload = ""
[IO.File]::WriteAllBytes($zipPath, [Convert]::FromBase64String($payload))
Expand-Archive -Path $zipPath -DestinationPath $tempRoot -Force

Copy-Item -Force (Join-Path $tempRoot "UltraSpeakerCpp.exe") (Join-Path $installDir "UltraSpeakerCpp.exe")
Copy-Item -Force (Join-Path $tempRoot "config.json") (Join-Path $installDir "config.json")
if (Test-Path (Join-Path $installDir "assets")) { Remove-Item -Recurse -Force (Join-Path $installDir "assets") }
Copy-Item -Recurse -Force (Join-Path $tempRoot "assets") (Join-Path $installDir "assets")

$exePath = Join-Path $installDir "UltraSpeakerCpp.exe"
$hkcuLayers = "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers"
$hklmLayers = "HKLM:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Layers"
New-Item -Force -Path $hkcuLayers | Out-Null
New-ItemProperty -Path $hkcuLayers -Name $exePath -Value "RUNASADMIN" -PropertyType String -Force | Out-Null
try {
    New-Item -Force -Path $hklmLayers | Out-Null
    New-ItemProperty -Path $hklmLayers -Name $exePath -Value "RUNASADMIN" -PropertyType String -Force | Out-Null
} catch {
    Write-Warning "No se pudo guardar RUNASADMIN en HKLM; quedo guardado para el usuario actual."
}

$shortcutPath = Join-Path ([Environment]::GetFolderPath("Desktop")) "UltraSpeaker.lnk"
try {
    $shell = New-Object -ComObject WScript.Shell
    $shortcut = $shell.CreateShortcut($shortcutPath)
    $shortcut.TargetPath = $exePath
    $shortcut.WorkingDirectory = $installDir
    $shortcut.IconLocation = "$exePath,0"
    $shortcut.Save()
} catch {
    Write-Warning "No se pudo crear el acceso directo del escritorio."
}

Remove-Item -Recurse -Force $tempRoot -ErrorAction SilentlyContinue
Write-Host "UltraSpeaker instalado en: $installDir"
Write-Host "Permiso RUNASADMIN guardado para: $exePath"
Write-Host "Ejecute UltraSpeakerCpp.exe o el acceso directo UltraSpeaker del escritorio."

